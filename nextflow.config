# =================================================
# PARAMETERS: User-defined inputs and global settings
# =================================================
params {
    input        = "data/"        
    outdir       = "results/"     
    sample       = "sample1"      
    genome       = "hg38"         

    max_cpus     = 8              
    max_memory   = '32 GB'        
}


# =================================================
# PROCESS: Resource allocation and execution behavior
# =================================================
process {

    executor = 'local'

    # Default resources (safe baseline)
    cpus   = 2
    memory = '4 GB'
    time   = '2h'

    # Enforce global limits
    resourceLimits = [
        cpus: params.max_cpus,
        memory: params.max_memory
    ]

    # Error handling
    errorStrategy = 'retry'
    maxRetries    = 2

    # Faster failure visibility
    maxErrors = '-1'

    # -------------------------
    # Process-specific settings
    # -------------------------

    withName:QC {
        cpus   = 2
        memory = '4 GB'
        time   = '1h'
    }

    withName:PREPROCESS {
        cpus   = 2
        memory = '6 GB'
        time   = '2h'
    }

    withName:CLUSTER {
        cpus   = 4
        memory = '8 GB'
        time   = '4h'
    }

    withName:DEG {
        cpus   = 4
        memory = '8 GB'
        time   = '4h'
    }

    withName:TRAJECTORY {
        cpus   = 4
        memory = '10 GB'
        time   = '6h'
    }

    withName:PATHWAY {
        cpus   = 2
        memory = '6 GB'
        time   = '3h'
    }
}


# =================================================
# PROFILES: Execution environments
# =================================================
profiles {

    standard {
        process.executor = 'local'
    }

    docker {
        docker.enabled = true
        process.container = 'scrna-pipeline:latest'
        docker.runOptions = '-u $(id -u):$(id -g)'   # avoids permission issues
    }

    conda {
        conda.enabled = true
        conda.autoActivate = true
        process.conda = "envs/environment.yml"
    }

    slurm {
        process.executor = 'slurm'
        process.queue    = 'compute'
        process.clusterOptions = '--account=default'
    }
}


# =================================================
# REPORTING: Execution reports
# =================================================
timeline {
    enabled = true
    file = "${params.outdir}/timeline.html"
}

report {
    enabled = true
    file = "${params.outdir}/report.html"
}

trace {
    enabled = true
    file = "${params.outdir}/trace.txt"
}

dag {
    enabled = true
    file = "${params.outdir}/workflow_dag.png"
}


# =================================================
# WORK DIRECTORY
# =================================================
workDir = "work/"


# =================================================
# CLEANUP
# =================================================
cleanup = true